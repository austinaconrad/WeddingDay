<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hannah & Austin's Wedding</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset & Base ────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:   #FAF8F5;
      --white:   #FFFFFF;
      --gold:    #9E8260;
      --gold-lt: #C9AC88;
      --ink:     #1E1E1E;
      --ink-lt:  #5A5A5A;
      --border:  #E8E2DA;
      --serif:   'Cormorant Garamond', Georgia, serif;
      --sans:    'Jost', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--ink);
      font-family: var(--sans);
      font-weight: 300;
      font-size: 16px;
      line-height: 1.7;
    }

    /* ── Nav ─────────────────────────────────────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      padding: 1.25rem 2rem;
      background: rgba(250, 248, 245, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
    }

    nav a {
      font-family: var(--sans);
      font-size: 0.75rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink-lt);
      text-decoration: none;
      transition: color 0.2s;
    }

    nav a:hover { color: var(--gold); }

    /* ── Section shell ───────────────────────────────────────────────── */
    section {
      max-width: 860px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .section-label {
      display: block;
      font-family: var(--sans);
      font-size: 0.7rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    h2 {
      font-family: var(--serif);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 300;
      line-height: 1.2;
      color: var(--ink);
      margin-bottom: 2.5rem;
    }

    .divider {
      width: 48px;
      height: 1px;
      background: var(--gold-lt);
      margin: 0 auto 2.5rem;
    }

    /* ── Hero ────────────────────────────────────────────────────────── */
    #hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding-top: 4rem;
      max-width: 100%;
      gap: 0;
    }

    .hero-photo {
      height: 100vh;
      position: relative;
      overflow: hidden;
    }

    .hero-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 4rem 3rem;
    }

    @media (max-width: 768px) {
      #hero {
        grid-template-columns: 1fr;
        min-height: auto;
      }
      .hero-photo {
        height: 60vw;
        min-height: 280px;
      }
      .hero-text {
        padding: 3rem 2rem;
      }
    }

    .hero-eyebrow {
      font-family: var(--sans);
      font-size: 0.7rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    .hero-names {
      font-family: var(--serif);
      font-size: clamp(3rem, 10vw, 7rem);
      font-weight: 300;
      line-height: 1.05;
      color: var(--ink);
      margin-bottom: 1.5rem;
    }

    .hero-names span {
      display: block;
      font-style: italic;
      font-size: 0.6em;
      color: var(--gold-lt);
      letter-spacing: 0.05em;
    }

    .hero-date {
      font-family: var(--serif);
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      font-weight: 300;
      color: var(--ink-lt);
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }

    .hero-location {
      font-family: var(--sans);
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold-lt);
    }

    /* ── Schedule ────────────────────────────────────────────────────── */
    #schedule { text-align: center; }

    .timeline {
      display: grid;
      gap: 0;
      max-width: 480px;
      margin: 0 auto;
      text-align: left;
      position: relative;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 5.5rem;
      top: 0.4rem;
      bottom: 0.4rem;
      width: 1px;
      background: var(--border);
    }

    .timeline-item {
      display: grid;
      grid-template-columns: 5rem 1fr;
      gap: 1.5rem;
      padding: 1.25rem 0;
      position: relative;
    }

    .timeline-item:not(:last-child) {
      border-bottom: 1px solid transparent;
    }

    .timeline-time {
      font-family: var(--serif);
      font-size: 0.85rem;
      font-style: italic;
      color: var(--gold);
      padding-top: 0.1rem;
      text-align: right;
    }

    .timeline-content {
      padding-left: 1.5rem;
      position: relative;
    }

    .timeline-content::before {
      content: '';
      position: absolute;
      left: -0.35rem;
      top: 0.55rem;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--gold-lt);
      border: 2px solid var(--cream);
      outline: 1px solid var(--gold-lt);
    }

    .timeline-event {
      font-family: var(--serif);
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 0.2rem;
    }

    .timeline-detail {
      font-size: 0.8rem;
      color: var(--ink-lt);
    }

    /* ── Seating Chart ───────────────────────────────────────────────── */
    #seating { text-align: center; }

    .seating-search-wrap {
      position: relative;
      max-width: 380px;
      margin: 0 auto 2.5rem;
    }

    .seating-search {
      width: 100%;
      padding: 0.85rem 1.25rem 0.85rem 3rem;
      font-family: var(--sans);
      font-size: 0.9rem;
      font-weight: 300;
      border: 1px solid var(--border);
      border-radius: 2px;
      background: var(--white);
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s;
    }

    .seating-search:focus { border-color: var(--gold-lt); }
    .seating-search::placeholder { color: var(--ink-lt); opacity: 0.6; }

    .search-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gold-lt);
      pointer-events: none;
    }

    .seating-highlight {
      display: none;
      background: #FDF6EC;
      border: 1px solid var(--gold-lt);
      border-radius: 2px;
      padding: 1rem 1.5rem;
      margin: 0 auto 2rem;
      max-width: 380px;
      font-family: var(--serif);
      font-size: 1.1rem;
      color: var(--ink);
    }

    .seating-highlight strong { color: var(--gold); }

    .tables-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.25rem;
      text-align: left;
    }

    .table-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 2px;
      padding: 1.25rem 1.5rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .table-card.highlighted {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(158, 130, 96, 0.1);
    }

    .table-name {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--gold);
      margin-bottom: 0.75rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }

    .table-guests {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .table-guests li {
      font-size: 0.85rem;
      color: var(--ink-lt);
      transition: color 0.2s;
    }

    .table-guests li.match {
      color: var(--ink);
      font-weight: 400;
    }

    /* ── Photos ──────────────────────────────────────────────────────── */
    #photos {
      text-align: center;
      background: var(--white);
      max-width: 100%;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    #photos .inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .photo-icon {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
      opacity: 0.35;
    }

    .photos-body {
      font-family: var(--serif);
      font-size: 1.15rem;
      color: var(--ink-lt);
      max-width: 480px;
      margin: 0 auto 2.5rem;
      font-style: italic;
    }

    .btn {
      display: inline-block;
      padding: 0.85rem 2.5rem;
      font-family: var(--sans);
      font-size: 0.75rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid var(--gold);
      color: var(--gold);
      background: transparent;
      border-radius: 2px;
      transition: background 0.2s, color 0.2s;
    }

    .btn:hover {
      background: var(--gold);
      color: var(--white);
    }

    .btn-note {
      display: block;
      margin-top: 1rem;
      font-size: 0.75rem;
      color: var(--ink-lt);
      opacity: 0.6;
    }

    /* ── Footer ──────────────────────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 3rem 2rem;
      font-family: var(--serif);
      font-style: italic;
      font-size: 1rem;
      color: var(--gold-lt);
    }

    /* ── Responsive ──────────────────────────────────────────────────── */
    @media (max-width: 600px) {
      nav { gap: 1.5rem; }
      .timeline::before { left: 4.5rem; }
      .timeline-item { grid-template-columns: 4rem 1fr; }
    }
  </style>
</head>
<body>

  <!-- ── Navigation ──────────────────────────────────────────────────── -->
  <nav>
    <a href="#hero">Home</a>
    <a href="#schedule">Schedule</a>
    <a href="#seating">Seating</a>
    <a href="#photos">Photos</a>
  </nav>

  <!-- ── Hero ────────────────────────────────────────────────────────── -->
  <section id="hero">
    <!-- ✏️ Save your photo as "couple.jpg" in the same folder as index.html -->
    <div class="hero-photo">
      <img src="couple.jpg" alt="The happy couple" />
    </div>
    <div class="hero-text">
      <p class="hero-eyebrow">We're getting married</p>
      <h1 class="hero-names">
        Hannah &amp; Austin
      </h1>
      <p class="hero-date">Saturday, the Twenty-Sixth of September, Two Thousand Twenty-Six</p>
      <p class="hero-location">Licking County Springs Country Club · Newark, OH</p>
    </div>
  </section>

  <!-- ── Schedule ─────────────────────────────────────────────────────── -->
  <section id="schedule">
    <span class="section-label">Day of</span>
    <h2>Schedule</h2>
    <div class="divider"></div>

    <div class="timeline">
      <div class="timeline-item">
        <span class="timeline-time">4:00 pm</span>
        <div class="timeline-content">
          <p class="timeline-event">Guest Arrival</p>
          <p class="timeline-detail">Please be seated by 4:15 pm</p>
        </div>
      </div>
      <div class="timeline-item">
        <span class="timeline-time">4:30 pm</span>
        <div class="timeline-content">
          <p class="timeline-event">Ceremony</p>
          <p class="timeline-detail">Licking County Springs Country Club</p>
        </div>
      </div>
      <div class="timeline-item">
        <span class="timeline-time">5:00 pm</span>
        <div class="timeline-content">
          <p class="timeline-event">Cocktail Hour</p>
          <p class="timeline-detail">Terrace & Garden</p>
        </div>
      </div>
      <div class="timeline-item">
        <span class="timeline-time">6:00 pm</span>
        <div class="timeline-content">
          <p class="timeline-event">Dinner &amp; Dancing</p>
          <p class="timeline-detail">Main Ballroom</p>
        </div>
      </div>
      <div class="timeline-item">
        <span class="timeline-time">10:00 pm</span>
        <div class="timeline-content">
          <p class="timeline-event">Grand Exit</p>
          <p class="timeline-detail">Join us for a sparkler send-off</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Seating Chart ────────────────────────────────────────────────── -->
  <section id="seating">
    <span class="section-label">Find your seat</span>
    <h2>Seating Chart</h2>
    <div class="divider"></div>

    <div class="seating-search-wrap">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="seating-search"
        type="text"
        placeholder="Search your name…"
        oninput="searchGuests(this.value)"
        autocomplete="off"
      />
    </div>

    <div class="seating-highlight" id="seating-highlight"></div>

    <div class="tables-grid" id="tables-grid">
      <!-- Tables rendered by JS below -->
    </div>
  </section>

  <!-- ── Photos ───────────────────────────────────────────────────────── -->
  <div id="photos">
    <div class="inner">
      <div class="photo-icon">📷</div>
      <span class="section-label">Memories</span>
      <h2>Share Your Photos</h2>
      <div class="divider"></div>
      <p class="photos-body">
        Capture the magic! Upload your photos to our shared album so we can all
        relive every moment together.
      </p>
      <!-- ✏️ Replace the href with your shared Google Photos album link -->
      <a class="btn" href="https://photos.google.com" target="_blank" rel="noopener">
        Open Photo Album
      </a>
      <span class="btn-note">Opens Google Photos · No account required to view</span>
    </div>
  </div>

  <!-- ── Footer ────────────────────────────────────────────────────────── -->
  <footer>
    Hannah Vaughn &amp; Austin Conrad · September 26, 2026
  </footer>

  <!-- ── Seating Chart Data & Logic ────────────────────────────────────── -->
  <script>
    /**
     * ✏️ SEATING DATA — edit this to match your actual guest list.
     *    Each table has a "name" and an array of "guests".
     *    Remove placeholder entries and add your real guests.
     */
    const TABLES = [
      {
        name: "Table 1 — Sweetheart",
        guests: ["Bride & Groom"]
      },
      {
        name: "Table 2 — Family",
        guests: [
          "Jane Smith",
          "John Smith",
          "Emily Smith",
          "Robert Smith",
          "Susan Smith",
          "Michael Smith"
        ]
      },
      {
        name: "Table 3 — Family",
        guests: [
          "Alice Johnson",
          "David Johnson",
          "Laura Johnson",
          "Tom Johnson",
          "Nancy Johnson",
          "Chris Johnson"
        ]
      },
      {
        name: "Table 4 — College Friends",
        guests: [
          "Olivia Brown",
          "Liam Brown",
          "Emma Davis",
          "Noah Davis",
          "Sophia Wilson",
          "Mason Wilson"
        ]
      },
      {
        name: "Table 5 — Work Friends",
        guests: [
          "Ava Martinez",
          "James Martinez",
          "Isabella Garcia",
          "Ethan Garcia",
          "Mia Anderson",
          "Alexander Anderson"
        ]
      },
      {
        name: "Table 6 — Childhood Friends",
        guests: [
          "Charlotte Thomas",
          "Benjamin Thomas",
          "Amelia Jackson",
          "Henry Jackson",
          "Harper White",
          "Lucas White"
        ]
      }
    ];

    /* ── Render tables ──────────────────────────────────────────────── */
    function renderTables(query) {
      const grid = document.getElementById('tables-grid');
      const q = (query || '').trim().toLowerCase();
      let matchTable = null, matchGuest = null;

      grid.innerHTML = TABLES.map((table, ti) => {
        const guestsHTML = table.guests.map(guest => {
          const isMatch = q.length >= 2 && guest.toLowerCase().includes(q);
          if (isMatch) { matchTable = table.name; matchGuest = guest; }
          return `<li class="${isMatch ? 'match' : ''}">${guest}</li>`;
        }).join('');

        const highlighted = q.length >= 2 &&
          table.guests.some(g => g.toLowerCase().includes(q));

        return `
          <div class="table-card ${highlighted ? 'highlighted' : ''}">
            <p class="table-name">${table.name}</p>
            <ul class="table-guests">${guestsHTML}</ul>
          </div>`;
      }).join('');

      /* Show/hide the highlight banner */
      const banner = document.getElementById('seating-highlight');
      if (matchGuest) {
        banner.innerHTML = `<strong>${matchGuest}</strong> is seated at <strong>${matchTable}</strong>`;
        banner.style.display = 'block';
      } else if (q.length >= 2) {
        banner.innerHTML = `No guest found matching "<strong>${q}</strong>"`;
        banner.style.display = 'block';
      } else {
        banner.style.display = 'none';
      }
    }

    function searchGuests(value) { renderTables(value); }

    /* Initial render */
    renderTables('');
  </script>

</body>
</html>
